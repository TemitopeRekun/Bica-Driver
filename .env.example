# Required for deployed builds
VITE_API_URL=https://your-backend-ngrok-or-render-url
VITE_FRONTEND_URL=https://your-frontend-ngrok-url

# Optional frontend integrations
VITE_GOOGLE_MAPS_API_KEY=
VITE_GEMINI_API_KEY=

# Optional Vite dev server override
# VITE_PORT=5173

# Optional local backend proxy target for Vite dev server
# VITE_PROXY_TARGET=http://localhost:3001
